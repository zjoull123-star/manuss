generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TaskRecord {
  id                 String             @id
  userId             String
  goal               String
  recipeId           String?
  status             String
  createdAt          DateTime
  updatedAt          DateTime
  currentPlanVersion Int
  planJson           String
  originJson         String?
  finalArtifactUri   String?
  finalArtifactValidationJson String?
  retryOfTaskId      String?
  cancelRequestedAt  DateTime?
  steps              TaskStepRecord[]
  checkpoints        CheckpointRecord[]
  artifacts          ArtifactRecord[]
  toolCalls          ToolCallRecord[]
  approvals          ApprovalRequestRecord[]
  jobs               TaskJobRecord[]
  events             TaskEventRecord[]
  memories           MemoryRecordModel[]
  summaries          TaskSummaryRecord[]
  references         TaskReferenceRecord[]
  artifactIndexes    ArtifactIndexRecord[]
  benchmarkItems     BenchmarkRunItemRecord[]

  @@index([userId])
}

model MemoryRecordModel {
  id        String   @id
  taskId    String
  stepId    String?
  summary   String
  createdAt DateTime
  task      TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model TaskStepRecord {
  key                String   @id
  taskId             String
  stepId             String
  orderIndex         Int
  title              String
  agent              String
  taskClass          String?
  qualityProfileJson String?
  attemptStrategyJson String?
  objective          String
  dependsOnJson      String
  status             String
  retryCount         Int
  successCriteriaJson String
  summary            String?
  inputArtifactsJson String
  outputArtifactsJson String
  structuredDataJson String
  evidencePackageJson String?
  qualityScore       Float?
  qualityDefectsJson String?
  missingEvidenceJson String?
  sourceCoverageScore Float?
  formatCompliance   String?
  attemptHistoryJson String?
  referenceArtifactIdsJson String?
  errorJson          String?
  task               TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, stepId])
  @@index([taskId, orderIndex])
}

model CheckpointRecord {
  id                 String   @id
  taskId             String
  planVersion        Int
  completedStepsJson String
  currentStepId      String?
  artifactUrisJson   String
  lastErrorJson      String?
  createdAt          DateTime
  task               TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model ArtifactRecord {
  id           String   @id
  taskId       String
  stepId       String?
  type         String
  uri          String
  title        String?
  summary      String?
  keywordsJson String?
  validated    Boolean?
  deliveryKind String?
  metadataJson String
  createdAt    DateTime
  task         TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)
  indexedEntries ArtifactIndexRecord[]

  @@index([taskId, createdAt])
}

model UserProfileRecord {
  userId          String   @id
  language        String
  outputStyle     String
  riskPolicy      String
  preferencesJson String
  updatedAt       DateTime
}

model ToolCallRecord {
  id         String   @id
  taskId      String
  stepId      String
  toolName    String
  action      String
  callerAgent String
  status      String
  durationMs  Int
  createdAt   DateTime
  task        TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model ApprovalRequestRecord {
  id           String   @id
  taskId       String
  stepId       String
  toolName     String
  action       String
  status       String
  reason       String
  payloadJson  String
  requestedAt  DateTime
  decidedAt    DateTime?
  decidedBy    String?
  decisionNote String?
  task         TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, stepId, requestedAt])
  @@index([status, requestedAt])
}

model TaskJobRecord {
  id          String   @id
  taskId      String
  kind        String
  status      String
  payloadJson String
  attempts    Int
  maxAttempts Int
  availableAt DateTime
  createdAt   DateTime
  updatedAt   DateTime
  lockedAt    DateTime?
  lockedBy    String?
  lastError   String?
  task        TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([status, availableAt, createdAt])
}

model TaskEventRecord {
  id        String   @id
  taskId     String
  kind       String
  level      String
  message    String
  stepId     String?
  jobId      String?
  payloadJson String
  createdAt  DateTime
  task       TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([kind, createdAt])
}

model TaskSummaryRecord {
  id        String   @id
  taskId    String
  userId    String
  taskClass String?
  recipeId  String?
  summary   String
  keywordsJson String
  validated Boolean
  createdAt DateTime
  task      TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([userId, createdAt])
  @@index([taskClass, validated, createdAt])
}

model ArtifactIndexRecord {
  id          String   @id
  taskId      String
  stepId      String?
  artifactId  String
  artifactType String
  uri         String
  title       String?
  summary     String?
  keywordsJson String
  validated   Boolean
  taskClass   String?
  recipeId    String?
  createdAt   DateTime
  task        TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)
  artifact    ArtifactRecord @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([artifactType, validated, createdAt])
  @@index([taskClass, validated, createdAt])
}

model TaskReferenceRecord {
  id             String   @id
  taskId         String
  sourceTaskId   String?
  sourceArtifactId String?
  reason         String
  metadataJson   String
  createdAt      DateTime
  task           TaskRecord @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
}

model BenchmarkRunRecord {
  id          String   @id
  name        String
  suite       String
  status      String
  startedAt   DateTime
  completedAt DateTime?
  createdAt   DateTime
  metadataJson String
  items       BenchmarkRunItemRecord[]

  @@index([createdAt])
  @@index([suite, createdAt])
}

model BenchmarkRunItemRecord {
  id              String   @id
  benchmarkRunId  String
  caseId          String
  taskId          String?
  completed       Boolean
  qualityScore    Float?
  fallbackUsed    Boolean
  artifactValidated Boolean
  latencyMs       Int?
  failureCategory String?
  createdAt       DateTime
  metadataJson    String
  run             BenchmarkRunRecord @relation(fields: [benchmarkRunId], references: [id], onDelete: Cascade)
  task            TaskRecord? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([benchmarkRunId, createdAt])
  @@index([caseId, createdAt])
}
